# ============================================================
# Sahara Smart Assistant v2.0 - Environment Variables
# إعدادات البيئة لمساعد سهارا الذكي
# ============================================================

# ── Telegram Bot ──
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# ── Ollama ──
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=mistral

# ── Proxmox VE ──
PROXMOX_HOST=10.0.9.10
PROXMOX_PORT=8006
PROXMOX_NODE=pve
PROXMOX_TOKEN_ID=root@pam!sahara
PROXMOX_TOKEN_SECRET=YOUR_TOKEN_SECRET_HERE

# ── n8n ──
N8N_HOST=10.0.9.10
N8N_PORT=5678
N8N_API_KEY=YOUR_N8N_API_KEY_HERE

# ── Server ──
PORT=3000
TZ=Asia/Riyadh
